    "legacy:build:dev": "esbuild app.source.jsx --bundle --format=esm --target=es2020 --outfile=app.js --external:./firebase-config.js* --external:https://www.gstatic.com/*",
    "test:pdf": "node scripts/verify-pdf-a4.cjs",
